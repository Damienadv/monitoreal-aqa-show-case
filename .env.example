# Database
DATABASE_URL=sqlite+aiosqlite:///./data/mock.db

# API Keys (dev-only, never use in production)
API_KEY_CAMERA=cam-key-dev-only
API_KEY_VIEWER=viewer-key-dev-only
API_KEY_ADMIN=admin-key-dev-only

# Retention policy
ARCHIVE_RETENTION_DAYS=30

# Webhook sink (для actions_runner; в тестах подменяется фикстурой)
WEBHOOK_SINK_URL=http://localhost:8001
